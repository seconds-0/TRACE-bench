{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/trace-per-turn-response.schema.json",
  "title": "TRACE Per-Turn Model Response",
  "type": "object",
  "required": ["turns"],
  "properties": {
    "turns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["entities", "totals"],
        "properties": {
          "entities": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "required": ["tokens"],
              "properties": {"tokens": {"type": "integer"}},
              "additionalProperties": true
            }
          },
          "totals": {
            "type": "object",
            "required": ["tokens"],
            "properties": {"tokens": {"type": "integer"}},
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

