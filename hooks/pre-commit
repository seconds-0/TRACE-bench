#!/usr/bin/env bash
# Run a fast test suite before committing. Fail commit on test failure.

set -euo pipefail

echo "[pre-commit] Running tests (pytest -q)..."
if ! command -v pytest >/dev/null 2>&1; then
  echo "[pre-commit] pytest not found. Install with: pip install pytest" >&2
  exit 1
fi

# Ensure mock mode so no network calls occur
export MOCK_STEEL_THREAD=1

pytest -q
status=$?
if [ $status -ne 0 ]; then
  echo "[pre-commit] Tests failed. Aborting commit." >&2
  exit $status
fi

echo "[pre-commit] Tests passed. Proceeding with commit."
exit 0

